    },
    {
      "cell_type": "code",
      "source": [
        "# --- A. Visualize Decision Boundary (Model Intelligence) ---\n",
        "plt.figure(figsize=(12, 8))\n",
        "\n",
        "# 1. Create a mesh grid to plot the decision regions\n",
        "x_min, x_max = X['Daily Internet Usage'].min() - 10, X['Daily Internet Usage'].max() + 10\n",
        "y_min, y_max = X['Daily Time Spent on Site'].min() - 10, X['Daily Time Spent on Site'].max() + 10\n",
        "xx, yy = np.meshgrid(np.arange(x_min, x_max, 1), np.arange(y_min, y_max, 1))\n",
        "\n",
        "# 2. Predict over the grid (we use dummy values for other features to keep it 2D)\n",
        "# Note: This assumes 'Daily Internet Usage' and 'Daily Time Spent on Site' are the key drivers\n",
        "grid_data = pd.DataFrame(0, index=np.arange(len(xx.ravel())), columns=X.columns)\n",
        "grid_data['Daily Internet Usage'] = xx.ravel()\n",
        "grid_data['Daily Time Spent on Site'] = yy.ravel()\n",
        "grid_data_scaled = scaler.transform(grid_data)\n",
        "\n",
        "Z = self_model.predict(grid_data_scaled)\n",
        "Z = Z.reshape(xx.shape)\n",
        "\n",
        "# 3. Plot the Decision Boundary\n",
        "plt.contourf(xx, yy, Z, alpha=0.2, cmap='RdYlGn')\n",
        "\n",
        "# 4. Overlay the actual user data\n",
        "sns.scatterplot(x='Daily Internet Usage', y='Daily Time Spent on Site',\n",
        "                hue='Clicked on Ad', data=df_clean,\n",
        "                palette={0: 'red', 1: 'green'}, alpha=0.6, edgecolor='w', s=60)\n",
        "\n",
        "plt.title('ConnectSphere: Learned Decision Boundary\\n(Green Shaded = Optimized Targeting Zone)', fontsize=16)\n",
        "plt.xlabel('Daily Internet Usage (minutes)', fontsize=12)\n",
        "plt.ylabel('Daily Time Spent on Site (minutes)', fontsize=12)\n",
        "plt.legend(title='Actual Outcome', loc='upper right')\n",
        "\n",
        "plt.savefig('model_intelligence_map.png')\n",
        "plt.show()\n",
        "\n",
        "print(\"\\nVisualization complete: The shaded regions show where the model 'self-corrected' to prioritize ad spend.\")"
      ],
