        "import pandas as pd # Import pandas for data manipulation\n",
        "import numpy as np # Import numpy for numerical operations\n",
        "\n",
        "# --- Machine Learning & Self-Learning Imports ---\n",
        "from sklearn.model_selection import train_test_split # Import for splitting data\n",
        "from sklearn.linear_model import LogisticRegression # Import the Logistic Regression model\n",
        "from sklearn.preprocessing import StandardScaler # Import for feature scaling\n",
        "\n",
        "# NEW: Import for Self-Learning (Semi-Supervised)\n",
        "from sklearn.semi_supervised import SelfTrainingClassifier\n",
        "\n",
        "# --- Evaluation Metrics ---\n",
        "from sklearn.metrics import classification_report, confusion_matrix, accuracy_score\n",
        "\n",
        "# --- Visualization ---\n",
        "import matplotlib.pyplot as plt # Import for basic plotting\n",
        "import seaborn as sns\n",
        "\n",
        "# Set professional aesthetics\n",
        "sns.set_style('whitegrid')\n",
        "%matplotlib inline"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# --- 1. Load Data ---\n",
        "url = 'https://raw.githubusercontent.com/ShikhaChauhan20/Ad-Click-Prediction-Analysis.ipynb/main/advertising.csv'\n",
        "df = pd.read_csv(url)\n",
        "print(\"Dataset loaded successfully from GitHub.\")\n",
        "\n",
        "# --- 2. Clean Data ---\n",
        "df_clean = df.drop(['Ad Topic Line', 'City', 'Country', 'Timestamp'], axis=1)\n",
        "\n",
        "# --- 3. Split Features and Target ---\n",
        "X = df_clean.drop('Clicked on Ad', axis=1)\n",
        "y = df_clean['Clicked on Ad']\n",
        "\n",
        "# --- 4. Standard Train/Test Split ---\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)\n",
        "\n",
        "# --- 5. Scaling ---\n",
        "scaler = StandardScaler()\n",
        "X_train_scaled = scaler.fit_transform(X_train)\n",
        "X_test_scaled = scaler.transform(X_test)\n",
        "\n",
        "# --- 6. SELF-LEARNING MODIFICATION ---\n",
        "# We simulate a \"Self-Learning\" environment by hiding 30% of our training labels.\n",
        "# In Scikit-Learn, unlabeled data must be marked as -1.\n",
        "y_train_self_learning = y_train.copy().values\n",
        "rng = np.random.RandomState(42)\n",
        "random_unlabeled_mask = rng.rand(y_train_self_learning.shape[0]) < 0.3\n",
        "\n",
        "y_train_self_learning[random_unlabeled_mask] = -1\n",
        "\n",
        "print(f\"Data prepared and scaled with {X.shape[1]} features.\")\n",
        "print(f\"Self-Learning Ready: {np.sum(y_train_self_learning == -1)} samples marked as 'Unlabeled' for the model to learn from.\")"
      ],
      "metadata": {
        "id": "k9p8i23nHMrP"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# --- A. SELF-LEARNING MODEL TRAINING ---\n",
        "# Using the unlabeled data (-1) prepared in the previous step\n",
        "base_lr = LogisticRegression(solver='liblinear', random_state=42)\n",
        "self_model = SelfTrainingClassifier(base_lr, threshold=0.8)\n",
        "\n",
        "# Train using the mixed labeled and unlabeled data\n",
        "self_model.fit(X_train_scaled, y_train_self_learning)\n",
        "\n",
        "# Generate predictions for evaluation\n",
        "predictions = self_model.predict(X_test_scaled)\n",
        "\n",
        "# --- B. MODEL EVALUATION ---\n",
        "print(\"\\n--- 1. Confusion Matrix (Self-Learning) ---\")\n",
        "print(confusion_matrix(y_test, predictions))\n",
        "\n",
        "print(\"\\n--- 2. Classification Report ---\")\n",
        "print(classification_report(y_test, predictions))\n",
        "\n",
        "# --- C. REINFORCEMENT LEARNING: CORRECTING FAILURES ---\n",
        "# This simulates how the model \"corrects\" itself during a live campaign\n",
        "class AdAgent:\n",
        "    def __init__(self, n_ads=3):\n",
        "        self.q_values = np.zeros(n_ads) # Estimated success for each ad\n",
        "        self.counts = np.zeros(n_ads)\n",
        "        self.epsilon = 0.2 # 20% exploration to fix failures\n",
        "\n",
        "    def act(self):\n",
        "        if np.random.rand() < self.epsilon:\n",
        "            return np.random.randint(len(self.q_values)) # Explore\n",
        "        return np.argmax(self.q_values) # Exploit best ad\n",
        "\n",
        "    def learn(self, ad_idx, reward):\n",
        "        self.counts[ad_idx] += 1\n",
        "        self.q_values[ad_idx] += (reward - self.q_values[ad_idx]) / self.counts[ad_idx]\n",
        "\n",
        "# Run a sample test: Ad 2 is the best (0.8 CTR), Ad 0 is failing (0.1 CTR)\n",
        "agent = AdAgent()\n",
        "true_rewards = [0.1, 0.3, 0.8]\n",
        "\n",
        "print(\"\\n--- 3. Live Ad Test (Reinforcement Learning Correction) ---\")\n",
        "for i in range(1, 101):\n",
        "    chosen_ad = agent.act()\n",
        "    reward = 1 if np.random.rand() < true_rewards[chosen_ad] else 0\n",
        "    agent.learn(chosen_ad, reward)\n",
        "\n",
        "    if i % 25 == 0:\n",
        "        print(f\"User {i}: Chosen Ad {chosen_ad} | Current Success Estimates: {agent.q_values.round(2)}\")\n",
        "\n",
        "# --- 4. Corrected Feature Coefficients ---\n",
        "print(\"\\n--- 4. Feature Coefficients for Business Insight ---\")\n",
        "feature_names = X.columns\n",
        "\n",
        "# We need the fitted underlying model.\n",
        "# In SelfTrainingClassifier, this is usually stored in 'base_estimator_' after fitting.\n",
        "try:\n",
        "    coefficients = self_model.base_estimator_.coef_[0]\n",
        "except AttributeError:\n",
        "    # Backup: some versions store it directly in the object's estimator\n",
        "    coefficients = self_model.estimator_.coef_[0]\n",
        "\n",
        "feature_importance = pd.DataFrame({'Feature': feature_names, 'Coefficient': coefficients})\n",
        "feature_importance['Impact'] = np.abs(feature_importance['Coefficient'])\n",
        "feature_importance = feature_importance.sort_values(by='Impact', ascending=False).drop('Impact', axis=1)\n",
        "\n",
        "print(feature_importance)"
      ],
      "metadata": {
        "id": "DUpQ-ry5Omf6"
      },
      "execution_count": null,
